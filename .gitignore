# ── OS & IDE ───────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# ── Secrets & environment ──────────────────────────────────
.env
.env.local
.env.*.local
*.local

# ── Dependencies & virtual envs ────────────────────────────
node_modules/
vendor/
__pycache__/
*.egg-info/
.venv/
venv/

# ── Runtime & build artifacts ──────────────────────────────
*.log
*.pid
dist/
build/

# ── Private research & temporary files ─────────────────────
research/
projects/bugs/

# ── Upstream plugin repo (managed separately) ──────────────
skills/claude/pm-skills/

# ── Individual project repositories ────────────────────────
# Each project under active/experiments/archive is its own git repo.
# Root workspace tracks only the shared structure and templates.
projects/active/*/
!projects/active/.gitkeep
projects/experiments/*/
!projects/experiments/.gitkeep
projects/archive/*/
!projects/archive/.gitkeep
